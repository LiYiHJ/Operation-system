+    def _compute_header_structure_score(self, field_mappings: list[dict], stats: dict, header_block: dict | None, flattened_headers: list[str] | None) -> tuple[float, list[str]]:
+        candidate = max(int(stats.get('candidateColumns') or 0), 1)
+        mapped = int(stats.get('mappedCount') or 0)
