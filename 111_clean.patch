+    def _strict_ru_mapping(self, norm_col: str) -> tuple[str | None, str | None]:
+        if norm_col in self._RU_GOLDEN_MAPPING:
+            return self._RU_GOLDEN_MAPPING[norm_col]['canonical'], 'ru_strict_golden'
+        if norm_col.startswith('отменено товаров'):
+            return 'items_canceled', 'ru_strict_pattern'
+        if norm_col.startswith('возвращено товаров'):
+            return 'items_returned', 'ru_strict_pattern'
+        return None, None
