+    def _compute_ru_mapping_quality(self, field_mappings: list[dict]) -> dict:
+        relevant = [m for m in field_mappings if self._normalize_header(m.get('originalField') or '') in self._RU_GOLDEN_MAPPING]
+        correctly = 0
+        wrongly = 0
+        unmapped = 0
+        details: list[dict] = []
+        for m in relevant:
+            raw = self._normalize_header(m.get('originalField') or '')
+            expected = self._RU_GOLDEN_MAPPING.get(raw, {})
+            got = m.get('standardField')
+            if not got:
+                unmapped += 1
+                status = 'unmapped'
+            elif got == expected.get('canonical'):
+                correctly += 1
+                status = 'correct'
+            else:
+                wrongly += 1
+                status = 'wrong'
+            details.append({
+                'originalField': m.get('originalField'),
+                'expectedCanonical': expected.get('canonical'),
+                'expectedFactTarget': expected.get('factTarget'),
+                'actualCanonical': got,
+                'status': status,
+            })
+        return {
+            'correctlyMappedCount': correctly,
+            'wronglyMappedCount': wrongly,
+            'unmappedCount': unmapped,
+            'goldenTotal': len(relevant),
+            'details': details,
