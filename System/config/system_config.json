{
  "system": {
    "name": "V5.1 跨境电商智能运营系统",
    "version": "5.1.0",
    "description": "智能 SKU 运营分析和策略推荐系统"
  },
  
  "profit_solver": {
    "discount_ratios": [0.95, 0.9, 0.85, 0.8, 0.75],
    "break_even_threshold": 0.05,
    "loss_threshold": -5.0
  },
  
  "strategy_engine": {
    "ctr_thresholds": {
      "excellent": 0.03,
      "good": 0.02,
      "poor": 0.015,
      "critical": 0.01
    },
    "roas_thresholds": {
      "excellent": 4.0,
      "good": 2.5,
      "poor": 1.5,
      "critical": 1.0
    },
    "days_of_supply_thresholds": {
      "excellent": 30,
      "good": 14,
      "poor": 7,
      "critical": 3
    },
    "rating_thresholds": {
      "excellent": 4.5,
      "good": 4.2,
      "poor": 3.8,
      "critical": 3.5
    },
    "return_rate_thresholds": {
      "excellent": 0.05,
      "good": 0.1,
      "poor": 0.15,
      "critical": 0.2
    }
  },
  
  "field_mapper": {
    "confidence_threshold": 0.7,
    "fuzzy_match_threshold": 0.6,
    "supported_platforms": ["ozon", "wildberries", "amazon", "aliexpress"],
    "supported_languages": ["ru", "zh", "en"]
  },
  
  "ingestion": {
    "max_preview_rows": 20,
    "supported_formats": ["xlsx", "csv", "json"],
    "encoding_detection": true,
    "auto_header_detection": true
  },
  
  "output": {
    "default_format": "json",
    "pretty_print": true,
    "include_suggestions": true,
    "include_discounts": true
  },
  
  "logging": {
    "level": "INFO",
    "format": "%(asctime)s - %(name)s - %(levelname)s - %(message)s",
    "file": "logs/v51-ops.log",
    "console": true
  },
  
  "performance": {
    "batch_size": 100,
    "max_workers": 4,
    "cache_enabled": true,
    "cache_ttl": 3600
  }
}
