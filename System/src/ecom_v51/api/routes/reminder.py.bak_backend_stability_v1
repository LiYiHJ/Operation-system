"""提醒中心 API"""

from __future__ import annotations

from datetime import datetime, timezone

from flask import Blueprint, jsonify, request
from sqlalchemy import func, inspect

from ecom_v51.db.models import AlertEvent, DimDate, ExecutionLog, FactOrdersDaily, FactReviewsDaily, ImportErrorLog, ReminderReadState, StrategyTask, UserAccount
from ecom_v51.db.session import get_session, get_engine
from ecom_v51.services.auth_service import AuthService

reminder_bp = Blueprint('reminder', __name__)

def _to_aware_utc(value):
    if value is None:
        return None
    if isinstance(value, str):
        try:
            value = datetime.fromisoformat(value)
        except ValueError:
            return None
    if value.tzinfo is None:
        return value.replace(tzinfo=timezone.utc)
    return value.astimezone(timezone.utc)


def _is_unread(item_time, read_at):
    item_dt = _to_aware_utc(item_time)
    read_dt = _to_aware_utc(read_at)
    if item_dt is None:
        return False
    if read_dt is None:
        return True
    return item_dt > read_dt

_auth_service = AuthService()


def _table_exists(table_name: str) -> bool:
    return table_name in set(inspect(get_engine()).get_table_names())


def _extract_token() -> str | None:
    auth = request.headers.get('Authorization', '')
    if auth.startswith('Bearer '):
        return auth.replace('Bearer ', '').strip()
    return None


def _get_current_user() -> dict[str, object] | None:
    token = _extract_token()
    return _auth_service.verify_token(token)


def _ensure_tables() -> None:
    engine = get_engine()
    existing = set(inspect(engine).get_table_names())

    # 读接口空库兼容：不在请求路径创建业务链表（strategy_task/execution_log 等）
    # 仅确保提醒已读状态所需表存在，避免 ack 接口写入失败。
    to_create = []
    if 'user_account' not in existing:
        to_create.append(UserAccount.__table__)
    if 'reminder_read_state' not in existing:
        to_create.append(ReminderReadState.__table__)

    if to_create:
        ReminderReadState.metadata.create_all(bind=engine, tables=to_create)


@reminder_bp.route('/list', methods=['GET'])
def reminder_list():
    _ensure_tables()
    shop_id = int(request.args.get('shopId', 1))
    current_user = _get_current_user()

    with get_session() as session:
        read_at = None
        if current_user:
            state = session.query(ReminderReadState).filter(ReminderReadState.user_id == int(current_user['id'])).first()
            read_at = state.last_read_at if state else None

        new_orders = 0
        new_reviews = 0
        latest_order_day = None
        latest_review_day = None
        system_alerts = []
        pending_confirmations = []
        exec_results = []
        import_exceptions = []

        if _table_exists('fact_orders_daily'):
            new_orders = int(session.query(func.coalesce(func.sum(FactOrdersDaily.ordered_qty), 0)).filter(FactOrdersDaily.shop_id == shop_id).scalar() or 0)
            if _table_exists('dim_date'):
                latest_order_day = (
                    session.query(func.max(DimDate.date_value))
                    .join(FactOrdersDaily, FactOrdersDaily.date_id == DimDate.id)
                    .filter(FactOrdersDaily.shop_id == shop_id)
                    .scalar()
                )

        if _table_exists('fact_reviews_daily'):
            new_reviews = int(session.query(func.coalesce(func.sum(FactReviewsDaily.new_reviews_count), 0)).filter(FactReviewsDaily.shop_id == shop_id).scalar() or 0)
            if _table_exists('dim_date'):
                latest_review_day = (
                    session.query(func.max(DimDate.date_value))
                    .join(FactReviewsDaily, FactReviewsDaily.date_id == DimDate.id)
                    .filter(FactReviewsDaily.shop_id == shop_id)
                    .scalar()
                )

        if _table_exists('alert_event'):
            system_alerts = session.query(AlertEvent).filter(AlertEvent.shop_id == shop_id).order_by(AlertEvent.detected_at.desc()).limit(10).all()
        if _table_exists('strategy_task'):
            pending_confirmations = session.query(StrategyTask).filter(StrategyTask.shop_id == shop_id, StrategyTask.status == 'pending').order_by(StrategyTask.created_at.desc()).limit(10).all()
            if _table_exists('execution_log'):
                exec_results = session.query(ExecutionLog).join(StrategyTask, StrategyTask.id == ExecutionLog.strategy_task_id).filter(StrategyTask.shop_id == shop_id).order_by(ExecutionLog.confirmed_at.desc()).limit(10).all()
        if _table_exists('import_error_log'):
            import_exceptions = session.query(ImportErrorLog).order_by(ImportErrorLog.created_at.desc()).limit(10).all()

        items = [
            {
                'id': 'orders',
                'category': 'new_orders',
                'title': '新订单提醒',
                'summary': f'今日累计订单 {new_orders} 单',
                'count': new_orders,
                'time': latest_order_day.isoformat() if latest_order_day else None,
                'source': '订单中心',
                'target': '/dashboard',
            },
            {
                'id': 'reviews',
                'category': 'new_reviews',
                'title': '新评价提醒',
                'summary': f'今日新增评价 {new_reviews} 条',
                'count': new_reviews,
                'time': latest_review_day.isoformat() if latest_review_day else None,
                'source': '评价中心',
                'target': '/dashboard',
            },
        ]
        items.extend([
            {'id': f'alert-{a.id}', 'category': 'system_alerts', 'title': '系统告警', 'summary': a.message, 'count': 1, 'time': a.detected_at.isoformat() if a.detected_at else None, 'source': '系统告警', 'target': '/dashboard'}
            for a in system_alerts
        ])
        items.extend([
            {'id': f'pending-{t.id}', 'category': 'pending_confirmations', 'title': '待确认动作', 'summary': f"{t.priority} {t.issue_summary}", 'count': 1, 'time': t.created_at.isoformat() if t.created_at else None, 'source': '策略清单', 'target': '/decision'}
            for t in pending_confirmations
        ])
        items.extend([
            {'id': f'exec-{x.id}', 'category': 'execution_writeback', 'title': '执行结果回写', 'summary': x.result_summary, 'count': 1, 'time': x.confirmed_at.isoformat() if x.confirmed_at else None, 'source': x.source_page, 'target': '/strategy'}
            for x in exec_results
        ])
        items.extend([
            {'id': f'import-{e.id}', 'category': 'import_exceptions', 'title': '导入异常', 'summary': e.error_message, 'count': 1, 'time': e.created_at.isoformat() if e.created_at else None, 'source': '数据导入', 'target': '/settings'}
            for e in import_exceptions
        ])

        items = sorted(items, key=lambda x: x.get('time') or '', reverse=True)
        unread_count = len([x for x in items if _is_unread(x.get('time'), read_at)])

        summary = {
            'new_orders': new_orders,
            'new_reviews': new_reviews,
            'system_alerts': len(system_alerts),
            'pending_confirmations': len(pending_confirmations),
            'execution_writeback': len(exec_results),
            'import_exceptions': len(import_exceptions),
            'unread': unread_count,
        }
        return jsonify({'summary': summary, 'items': items})


@reminder_bp.route('/ack', methods=['POST'])
def reminder_ack():
    _ensure_tables()
    current_user = _get_current_user()
    if not current_user:
        return jsonify({'error': '未登录'}), 401

    with get_session() as session:
        state = session.query(ReminderReadState).filter(ReminderReadState.user_id == int(current_user['id'])).first()
        now = datetime.now(timezone.utc)
        if not state:
            state = ReminderReadState(user_id=int(current_user['id']), last_read_at=now)
            session.add(state)
        else:
            state.last_read_at = now
        session.flush()
        return jsonify({'status': 'success', 'readAt': now.isoformat(), 'userId': current_user['id']})
