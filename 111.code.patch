+    @staticmethod
+    def _enforce_unique_field_mapping_hungarian(field_mappings: list[dict]) -> list[dict]:
+        """Conservative one-to-one assignment: keep the best per canonical and drop risky duplicates."""
+        grouped: dict[str, list[tuple[int, dict]]] = {}
+        for idx, item in enumerate(field_mappings):
+            canonical = item.get('standardField')
+            if not canonical:
+                continue
+            grouped.setdefault(str(canonical), []).append((idx, item))
+
+        for canonical, entries in grouped.items():
+            if len(entries) <= 1:
+                continue
+            if any(str(item.get('mappingSource') or '').startswith('ru_strict_') for _, item in entries):
+                continue
+            def _score(entry: tuple[int, dict]) -> tuple[int, float]:
+                _, item = entry
+                source = str(item.get('mappingSource') or '')
+                locked = 1 if source.startswith('ru_strict_') else 0
+                return (locked, float(item.get('confidence') or 0.0))
+
+            keep_idx, _ = max(entries, key=_score)
+            for idx, item in entries:
+                if idx == keep_idx:
+                    continue
+                item['reasons'] = (item.get('reasons') or []) + ['duplicate_canonical_dropped']
+                item['mappingSource'] = 'duplicate_dropped'
+                item['standardField'] = None
+                item['confidence'] = 0.0
+                field_mappings[idx] = item
+        return field_mappings
+
+    @staticmethod
+    def _build_row_error_summary(errors: list) -> dict:
+        summary = {'auto_fixed': 0, 'ignorable': 0, 'quarantined': 0, 'fatal': 0}
+        for err in errors or []:
+            msg = str(err).lower()
+            if any(k in msg for k in ['自动修复', 'auto_fixed']):
+                summary['auto_fixed'] += 1
+            elif any(k in msg for k in ['warning', 'ignorable', '可忽略']):
+                summary['ignorable'] += 1
+            elif any(k in msg for k in ['fatal', '致命']):
+                summary['fatal'] += 1
+            else:
+                summary['quarantined'] += 1
+        return summary
+
+
+    def _strict_ru_mapping(self, norm_col: str) -> tuple[str | None, str | None]:
+        if norm_col in self._RU_GOLDEN_MAPPING:
+            return self._RU_GOLDEN_MAPPING[norm_col]['canonical'], 'ru_strict_golden'
+        if norm_col.startswith('отменено товаров'):
+            return 'items_canceled', 'ru_strict_pattern'
+        if norm_col.startswith('возвращено товаров'):
+            return 'items_returned', 'ru_strict_pattern'
+        return None, None
+
+    def _compute_ru_mapping_quality(self, field_mappings: list[dict]) -> dict:
+        relevant = [m for m in field_mappings if self._normalize_header(m.get('originalField') or '') in self._RU_GOLDEN_MAPPING]
+        correctly = 0
+        wrongly = 0
+        unmapped = 0
+        details: list[dict] = []
+        for m in relevant:
+            raw = self._normalize_header(m.get('originalField') or '')
+            expected = self._RU_GOLDEN_MAPPING.get(raw, {})
+            got = m.get('standardField')
+            if not got:
+                unmapped += 1
+                status = 'unmapped'
+            elif got == expected.get('canonical'):
+                correctly += 1
+                status = 'correct'
+            else:
+                wrongly += 1
+                status = 'wrong'
+            details.append({
+                'originalField': m.get('originalField'),
+                'expectedCanonical': expected.get('canonical'),
+                'expectedFactTarget': expected.get('factTarget'),
+                'actualCanonical': got,
+                'status': status,
+            })
+        return {
+            'correctlyMappedCount': correctly,
+            'wronglyMappedCount': wrongly,
+            'unmappedCount': unmapped,
+            'goldenTotal': len(relevant),
+            'details': details,
+            'pass': wrongly == 0,
+        }
+
+    @staticmethod
+    def _extract_mapped_targets(field_mappings: list[dict]) -> set[str]:
+        targets: set[str] = set()
+        for mapping in field_mappings:
+            standard = (mapping or {}).get('standardField')
+            if standard and standard != 'unmapped':
+                targets.add(str(standard))
+        return targets
+
+    @staticmethod
+    def _core_hit_count(core_summary: dict | None) -> int:
+        if not core_summary:
+            return 0
+        keys = ['sku', 'orders_or_order_amount', 'impressions_total', 'product_card_visits_or_add_to_cart_total']
+        return sum(1 for k in keys if core_summary.get(k) is True)
+
+    def _compute_header_structure_score(self, field_mappings: list[dict], stats: dict, header_block: dict | None, flattened_headers: list[str] | None) -> tuple[float, list[str]]:
+        candidate = max(int(stats.get('candidateColumns') or 0), 1)
+        mapped = int(stats.get('mappedCount') or 0)
+        unmapped = int(stats.get('unmappedCount') or 0)
+        mapped_ratio = mapped / candidate
+        unmapped_density = unmapped / candidate
+        placeholder_density = len(stats.get('droppedPlaceholderColumns') or []) / max(int(stats.get('rawColumns') or candidate), 1)
+        block_span = 0
+        if header_block:
+            block_span = int(header_block.get('endRow', 0)) - int(header_block.get('startRow', 0)) + 1
+
+        streak = 0
+        best_streak = 0
+        for m in field_mappings:
+            if m.get('standardField'):
+                streak += 1
+                best_streak = max(best_streak, streak)
+            else:
+                streak = 0
+        explainable_run = best_streak / max(candidate, 1)
+        section_child_consistency = 1.0 if (flattened_headers and any('_' in h for h in flattened_headers)) else 0.0
+
+        score = (
+            mapped_ratio * 0.4
+            + (1 - min(unmapped_density, 1.0)) * 0.2
+            + (1 - min(placeholder_density, 1.0)) * 0.15
+            + min(explainable_run * 2.5, 1.0) * 0.15
+            + min(section_child_consistency + (0.3 if block_span >= 2 else 0), 1.0) * 0.1
+        )
+        score = round(max(0.0, min(1.0, score)), 3)
+        signals: list[str] = []
+        if block_span >= 2:
+            signals.append('multi_row_header_block')
+        if mapped_ratio < 0.45:
+            signals.append('low_effective_field_ratio')
+        if placeholder_density > 0.25:
+            signals.append('high_placeholder_density')
+        if unmapped_density > 0.55:
+            signals.append('high_unmapped_density')
+        if explainable_run < 0.18:
+            signals.append('short_explainable_column_run')
+        return score, signals
+
+    def _evaluate_semantic_gate(
+        self,
+        field_mappings: list[dict],
+        stats: dict,
+        transport_status: str = 'passed',
+        header_structure_score: float | None = None,
+        header_structure_risk_signals: list[str] | None = None,
+        recovery_diff: dict | None = None,
+    ) -> dict:
+        mapped_targets = self._extract_mapped_targets(field_mappings)
+
+        mandatory_groups = {
+            'sku': ['sku'],
+            'orders_or_order_amount': ['orders', 'order_amount'],
+            'impressions_total': ['impressions_total'],
+            'product_card_visits_or_add_to_cart_total': ['product_card_visits', 'add_to_cart_total'],
+        }
+        optional_pool = ['stock_total', 'rating_value', 'review_count', 'price_index_status', 'promo_days_count']
+
+        core_hits = {group: any(field in mapped_targets for field in fields) for group, fields in mandatory_groups.items()}
+        optional_hit_fields = [field for field in optional_pool if field in mapped_targets]
+
+        semantic_metrics = {
+            'mappedCount': stats.get('mappedCount', 0),
+            'unmappedCount': stats.get('unmappedCount', 0),
+            'candidateColumns': stats.get('candidateColumns', 0),
+            'mappingCoverage': stats.get('mappingCoverage', 0),
+            'mappedConfidence': stats.get('mappedConfidence', 0),
+            'correctlyMappedCount': stats.get('correctlyMappedCount'),
+            'wronglyMappedCount': stats.get('wronglyMappedCount'),
+            'headerStructureScore': header_structure_score,
+        }
+
+        semantic_pass = (
+            all(core_hits.values())
+            and len(optional_hit_fields) >= 2
+            and (semantic_metrics['mappingCoverage'] or 0) >= 0.5
+            and (semantic_metrics['mappedCount'] or 0) >= 8
+            and semantic_metrics['wronglyMappedCount'] in (None, 0)
+            and (header_structure_score is None or header_structure_score >= 0.42)
+        )
+
+        if semantic_pass:
+            semantic_status = 'passed'
+            semantic_gate_reasons = ['semantic_gate_met']
+        else:
+            semantic_status = 'risk' if transport_status == 'passed' else 'failed'
+            semantic_gate_reasons: list[str] = []
+            if (semantic_metrics['mappingCoverage'] or 0) < 0.5:
+                semantic_gate_reasons.append('low_mapping_coverage')
+            if (semantic_metrics['candidateColumns'] or 0) >= 60 or (semantic_metrics['unmappedCount'] or 0) >= 30:
+                semantic_gate_reasons.append('header_structure_risk')
+            if header_structure_score is not None and header_structure_score < 0.42:
+                semantic_gate_reasons.append('header_structure_score_low')
+            if (not all(core_hits.values())) or len(optional_hit_fields) < 2 or (semantic_metrics['mappedCount'] or 0) < 8:
+                semantic_gate_reasons.append('semantic_gate_not_met')
+            for signal in (header_structure_risk_signals or []):
+                if signal in {'high_placeholder_density', 'high_unmapped_density', 'short_explainable_column_run'}:
+                    semantic_gate_reasons.append(signal)
+            if recovery_diff:
+                semantic_gate_reasons.append(
+                    f"recovery_compare:mapped {recovery_diff.get('mappedCount_before', 0)}->{recovery_diff.get('mappedCount_after', 0)},"
+                    f"coverage {recovery_diff.get('mappingCoverage_before', 0)}->{recovery_diff.get('mappingCoverage_after', 0)}"
+                )
+            semantic_gate_reasons = sorted(set(semantic_gate_reasons)) or ['semantic_gate_not_met']
+
+        risk_override_reasons: list[str] = []
+
+        final_status = 'failed' if transport_status == 'failed' else ('passed' if semantic_status == 'passed' else 'risk')
+
+        return {
+            'transportStatus': transport_status,
+            'semanticStatus': semantic_status,
+            'finalStatus': final_status,
+            'semanticGateReasons': semantic_gate_reasons,
+            'riskOverrideReasons': risk_override_reasons,
+            'semanticAcceptanceReason': sorted(set((semantic_gate_reasons or []) + (risk_override_reasons or []))),
+            'semanticMetrics': semantic_metrics,
+            'coreFieldHitSummary': {
+                **core_hits,
+                'optionalFieldPool': optional_pool,
+                'optionalHitCount': len(optional_hit_fields),
+                'optionalHitFields': optional_hit_fields,
+                'mappedTargets': sorted(mapped_targets),
+            },
+            'semanticGateDefinition': {
+                'mandatoryGroups': mandatory_groups,
+                'optionalPool': optional_pool,
+                'optionalMinHits': 2,
+                'minimumMappingCoverage': 0.5,
+                'minimumMappedCount': 8,
+                'wronglyMappedCountMustBe': 0,
+            },
+        }
